<?xml version='1.0' encoding='utf-8'?>
<widget id="com.cleveradssolutions.cordova.example" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>CASCordovaExample</name>
    <description>Sample CAS.AI Cordova App</description>
    <author email="dev@cordova.apache.org" href="https://cordova.apache.org">
        Apache Cordova Team
    </author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <platform name="android">
        <preference name="android-targetSdkVersion" value="36" />
        <preference name="AndroidEdgeToEdge" value="true" />
        <allow-intent href="market:*" />
    </platform>
    <platform name="ios">
        <allow-intent href="itms:*" />
        <allow-intent href="itms-apps:*" />
        <preference name="deployment-target" value="13.0" />
    </platform>
    <plugin name="cordova-plugin-casai" spec="*">
        <variable name="IOS_CAS_ADAPTERS" value="-" />
        <variable name="ANDROID_CAS_ADAPTERS" value="-" />
    </plugin>
</widget>
